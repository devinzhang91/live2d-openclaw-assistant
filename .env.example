# ============================================
# Live2D AI 助手 - 环境变量配置示例
# 使用说明：
# 1. 复制本文件为 .env: cp .env.example .env
# 2. 修改 .env 中的配置值（不要修改 .env.example）
# 3. .env 文件不会被提交到 Git（已加入 .gitignore）
# ============================================

# ========== LLM 配置 ==========
# LLM 服务提供商: openai | volc
LLM_PROVIDER=openai

# OpenAI 兼容接口配置
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# 火山引擎 LLM 配置（当 LLM_PROVIDER=volc 时使用）
# VOLC_LLM_API_KEY=your-volc-api-key
# VOLC_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# VOLC_LLM_MODEL=doubao-1-5-pro-32k-250115

# ========== ASR 配置 ==========
# ASR 服务提供商: whisper | volc
ASR_PROVIDER=whisper

# Whisper 本地模型配置
WHISPER_MODEL_SIZE=base

# 火山引擎 ASR 配置（当 ASR_PROVIDER=volc 时使用）
# VOLC_ASR_APP_ID=your-app-id
# VOLC_ASR_ACCESS_KEY=your-access-key
# VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ========== TTS 配置 ==========
# TTS 服务提供商: edge | volc
TTS_PROVIDER=edge

# Edge TTS 配置（免费，无需密钥）
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 火山引擎 TTS 配置（当 TTS_PROVIDER=volc 时使用）
# VOLC_TTS_APP_ID=your-app-id
# VOLC_TTS_ACCESS_TOKEN=your-access-token
# VOLC_TTS_RESOURCE_ID=volc.service_type.10029
# VOLC_TTS_WS_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
# VOLC_TTS_VOICE_TYPE=zh_female_cancan_mars_bigtts

# ========== VAD 配置 ==========
VAD_MODEL_PATH=models/silero_vad_v4.onnx
VAD_THRESHOLD=0.5
VAD_SAMPLE_RATE=16000

# ========== 语音模式配置 ==========
# 语音交互模式:
#   pipeline       - 现有管道模式 (VAD → ASR → LLM → TTS)
#   realtime_volc  - 火山端到端实时语音
#   realtime_local - 本地端到端模型（占位）
# VOICE_MODE=pipeline

# ========== 火山端到端实时语音配置 (当 VOICE_MODE=realtime_volc 时使用) ==========
# 连接参数
# VOLC_REALTIME_APP_ID=your-app-id
# VOLC_REALTIME_ACCESS_KEY=your-access-key
# VOLC_REALTIME_RESOURCE_ID=volc.speech.dialog
# VOLC_REALTIME_APP_KEY=PlgvMymc7f3tQnJ6
# VOLC_REALTIME_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

# 模型版本: 1.2.1.1 (O2.0) 或 2.2.0.0 (SC2.0)
# VOLC_REALTIME_MODEL=1.2.1.1

# 音色 (必须带 _bigtts 后缀)
# O2.0: zh_male_yunzhou_jupiter_bigtts (男声), zh_female_xiaohe_jupiter_bigtt (女声)
# VOLC_REALTIME_VOICE=zh_male_yunzhou_jupiter_bigtts

# 功能开关
# VOLC_REALTIME_ENABLE_WEBSEARCH=false
# VOLC_REALTIME_ENABLE_MUSIC=false

# ========== 基础配置 ==========
HOST=0.0.0.0
PORT=8000
DEBUG=false
